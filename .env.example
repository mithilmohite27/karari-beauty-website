NEXT_PUBLIC_SITE_URL=https://kararibeauty.com

# Supabase public client values. These are safe to expose to browser code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. Server-side only. Never expose this in client components or browser bundles.
SUPABASE_SERVICE_ROLE_KEY=

# Customer Google sign-in uses Supabase Auth. Configure Google in Supabase Dashboard > Authentication > Providers > Google.
# Add this redirect URL in Supabase/Google settings:
# https://kararibeauty.com/auth/callback

# Razorpay test/live keys. Only NEXT_PUBLIC_RAZORPAY_KEY_ID is exposed to browser code.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
